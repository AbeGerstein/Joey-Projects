# PnF Bot configuration template.
# Copy this file to config.toml and fill in the values for your environment.
# config.toml is gitignored — do not commit real credentials.

[data]
# Path to the SQLite database file the bot persists OHLC, signals, and report state to.
# On Windows, use forward slashes or escaped backslashes.
db_path = "data/pnf_bot.db"

# Minimum price floor for the universe ($).
# Set per the OQ-009 resolution: $1.00.
min_price = 1.00

# How many years of OHLC history to backfill on first run.
backfill_years = 10


[norgate]
# Norgate Data Updater desktop app must be installed and authenticated on this host.
# The Python SDK reads from a local data store the updater maintains; there is no separate API key.
# See docs/research/norgate-data.md for setup instructions.

# Norgate database that defines the screening universe. "US Equities" is the
# default and contains all US-listed securities (the bot filters out ETFs,
# preferreds, BDCs, and other non-common-stock types at universe-load time).
universe_watchlist = "US Equities"

# Price adjustment mode for OHLC fetches.
# Options: "TotalReturn" (splits + dividends), "Capital" (splits only), "None".
# We want split + dividend adjusted for RS and signal computation.
price_adjustment = "TotalReturn"

# Equal-weight S&P 500 benchmark for Relative Strength calculations.
# Default "RSP" (Invesco S&P 500 Equal Weight ETF) is the verified-available
# choice. If post-subscription verification confirms "$SPXEW" (the raw index)
# is available on the advisor's tier, change to "$SPXEW" for the raw index.
benchmark_symbol = "RSP"


[scoring]
# Number of candidates surfaced in each report section.
# Locked 2026-05-18.
section_a_top_n = 10  # pre-momentum
section_b_top_n = 10  # in-momentum


[report]
# Where the report goes.
recipient_email = "Jromero816@yahoo.com"
subject_line = "Daily PnF stock report"

# Delivery time. The bot runs overnight; this controls when the email actually sends.
# 8:00 AM Mountain Time per advisor direction 2026-05-18.
delivery_time = "08:00"
delivery_timezone = "America/Denver"

# Output directory for archived reports.
archive_dir = "reports/archive"


[email]
# SMTP delivery. The bot uses stdlib smtplib so any SMTP server works.
# Both Yahoo and Gmail require an "app password" (generated via the
# provider's account-security page) — NOT the regular login password.
#
# === Option A — Yahoo SMTP (recommended if sending from a Yahoo account) ===
# Generate app password at https://login.yahoo.com/account/security
smtp_host = "smtp.mail.yahoo.com"
smtp_port = 587
smtp_user = "Jromero816@yahoo.com"                     # ← Yahoo address sending FROM
smtp_password = "REPLACE_WITH_YAHOO_APP_PASSWORD"      # ← 16-char app password
smtp_from = "PnF Bot <Jromero816@yahoo.com>"           # ← match smtp_user's address
smtp_use_tls = true
#
# === Option B — Gmail SMTP (alternative; comment out Yahoo block above) ===
# Generate app password at https://myaccount.google.com/apppasswords
# smtp_host = "smtp.gmail.com"
# smtp_port = 587
# smtp_user = "<gmail_address>@gmail.com"
# smtp_password = "REPLACE_WITH_GMAIL_APP_PASSWORD"
# smtp_from = "PnF Bot <<gmail_address>@gmail.com>"
# smtp_use_tls = true


[scheduler]
# When the analysis pipeline runs (24h clock, host local time).
# Default: 3:00 AM — overnight, well after market close, well before delivery time.
run_time = "03:00"
run_timezone = "America/Denver"


[logging]
log_dir = "logs"
log_level = "INFO"
