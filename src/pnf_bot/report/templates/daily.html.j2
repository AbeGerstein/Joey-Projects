<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Daily PnF stock report — {{ report.as_of_date }}</title>
  <style>
    @page { size: letter; margin: 0.6in; }
    body {
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Helvetica, Arial, sans-serif;
      color: #212121;
      font-size: 10pt;
      line-height: 1.4;
    }
    h1 { font-size: 18pt; margin: 0 0 4pt 0; color: #1a1a1a; }
    h2 { font-size: 14pt; margin: 18pt 0 6pt 0; border-bottom: 2px solid #2E7D32; padding-bottom: 2pt; color: #1a1a1a; }
    h3 { font-size: 11pt; margin: 12pt 0 4pt 0; color: #2E7D32; }
    .meta { color: #757575; font-size: 9pt; margin-bottom: 18pt; }
    .disclaimer {
      background: #FFF8E1;
      border-left: 3px solid #F57C00;
      padding: 8pt;
      margin: 12pt 0 18pt 0;
      font-size: 8pt;
      color: #5D4037;
    }
    .new-callout {
      background: #E8F5E9;
      border-left: 3px solid #2E7D32;
      padding: 8pt;
      margin: 12pt 0 18pt 0;
    }
    .new-callout h2 {
      margin-top: 0;
      border-bottom: none;
      color: #1B5E20;
    }
    .new-callout-list { list-style: none; padding-left: 0; margin: 6pt 0 0 0; }
    .new-callout-list li { padding: 3pt 0; }
    .candidate {
      page-break-inside: avoid;
      margin: 14pt 0;
      padding: 10pt;
      border: 1px solid #E0E0E0;
      border-radius: 4pt;
    }
    .candidate-header {
      display: flex;
      justify-content: space-between;
      align-items: baseline;
      margin-bottom: 6pt;
    }
    .symbol { font-size: 14pt; font-weight: bold; color: #1a1a1a; }
    .score { font-size: 10pt; color: #757575; }
    .badges { margin: 4pt 0 8pt 0; }
    .badge {
      display: inline-block;
      padding: 2pt 6pt;
      margin-right: 4pt;
      border-radius: 3pt;
      font-size: 8pt;
      font-weight: bold;
    }
    .badge-pre { background: #E3F2FD; color: #0D47A1; }
    .badge-in { background: #FFF3E0; color: #E65100; }
    .badge-fresh { background: #2E7D32; color: white; }
    .badge-rs-buy { background: #C8E6C9; color: #1B5E20; }
    .badge-rs-sell { background: #FFCDD2; color: #B71C1C; }
    .charts {
      display: flex;
      gap: 8pt;
      margin: 6pt 0;
    }
    .charts img { max-width: 100%; height: auto; }
    .pnf-chart { flex: 2; }
    .rs-chart { flex: 1; }
    .detail-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 6pt 12pt;
      margin: 6pt 0;
      font-size: 9pt;
    }
    .detail-grid .label { color: #757575; }
    .detail-grid .value { color: #212121; font-weight: 500; }
    .reasoning {
      margin: 6pt 0;
      padding: 6pt;
      background: #FAFAFA;
      border-left: 2px solid #BDBDBD;
      font-size: 9pt;
    }
    .signals-table {
      width: 100%;
      border-collapse: collapse;
      margin: 6pt 0;
      font-size: 8pt;
    }
    .signals-table th, .signals-table td {
      padding: 2pt 6pt;
      text-align: left;
      border-bottom: 1px solid #EEEEEE;
    }
    .signals-table th { background: #F5F5F5; color: #616161; font-weight: 600; }
    .bullish { color: #2E7D32; }
    .bearish { color: #C62828; }
    .footer {
      margin-top: 30pt;
      padding-top: 10pt;
      border-top: 1px solid #E0E0E0;
      font-size: 8pt;
      color: #9E9E9E;
      text-align: center;
    }
  </style>
</head>
<body>

<h1>Daily PnF stock report</h1>
<div class="meta">
  Report date: {{ report.as_of_date }}<br>
  Section A (pre-momentum): {{ report.section_a_top_n|length }} candidates ·
  Section B (in-momentum): {{ report.section_b_top_n|length }} candidates ·
  New patterns from last night: {{ report.new_patterns_last_night|length }}
</div>

<div class="disclaimer">
  <strong>DISCLAIMER.</strong> This report is an internal research aid generated by an
  automated screening tool. It is not investment advice and is not a recommendation to buy
  or sell any security. All investment decisions remain the advisor's responsibility.
</div>

{% if report.new_patterns_last_night %}
<div class="new-callout">
  <h2>New Patterns from Last Night</h2>
  <ul class="new-callout-list">
    {% for cand in report.new_patterns_last_night %}
    <li>
      <strong>{{ cand.symbol }}</strong>
      — {% if cand.matched_patterns %}{{ cand.matched_patterns[0].pattern_type|replace("_", " ") }}{% else %}pattern matched{% endif %}
      <span class="badge badge-fresh">FRESH</span>
      · score {{ "%.2f"|format(cand.final_score) }}
    </li>
    {% endfor %}
  </ul>
</div>
{% endif %}

<h2>Section A — Pre-Momentum Candidates ({{ section_a_details|length }})</h2>
{% for d in section_a_details %}
{% include "_candidate_card.html.j2" %}
{% endfor %}

<h2>Section B — In-Momentum Candidates ({{ section_b_details|length }})</h2>
{% for d in section_b_details %}
{% include "_candidate_card.html.j2" %}
{% endfor %}

<div class="footer">
  Generated by PnF Bot · {{ report.as_of_date }} · Internal use only — not investment advice.
</div>

</body>
</html>
